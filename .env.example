# =============================================================================
# Jewelry DIY 环境变量模板
# 本地：复制为 .env 或 .env.local 并填值
# 生产：在 Vercel → Project Settings → Environment Variables 填同名变量
# 流程详见 docs/shopify-deployment.md
# =============================================================================

# ─── 部署前填这 4 个（跑 OAuth 安装必需） ───────────────────────────────────
# 店铺域名，必须是 *.myshopify.com 形式
SHOPIFY_DOMAIN=

# Dev Dashboard → 左侧「设置」页：客户端 ID 和 加密密钥
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=

# OAuth 请求的 Admin API scope，保持与 Dev Dashboard 版本里 Required scopes 一致
SHOPIFY_APP_SCOPES=read_products,write_products,read_product_listings,read_inventory,read_files,write_files,read_orders


# ─── 跑完 /api/shopify/install 之后，从回调页复制 token 回填 ─────────────────
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_STOREFRONT_TOKEN=


# ─── 配完 Shopify Webhook 后回填 ────────────────────────────────────────────
# 后台「设置 → 通知 → Webhook」底部的签名密钥
SHOPIFY_WEBHOOK_SECRET=


# ─── 可选 ────────────────────────────────────────────────────────────────
# 只在调用 POST /api/revalidate 时需要；不用可留空
REVALIDATE_SECRET=

# 仅在生产走微信登录进 /admin 时需要；本地开发可只填 DEV_ADMIN_OPENID 绕过
WECHAT_APPID=
WECHAT_SECRET=
ADMIN_OPENIDS=
DEV_ADMIN_OPENID=
